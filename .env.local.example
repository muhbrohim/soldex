# Copy to .env.local and fill in. Never commit the real .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — used by scripts/migrate_to_supabase.ts ONLY.
# Never expose this to the browser. Never commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
